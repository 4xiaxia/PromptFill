# ============================================
# PromptFill 环境变量配置文件
# 说明：复制此文件为 .env，然后根据需要填写配置
# ============================================

# ==========【后端服务配置】==========

# 分享服务 API 地址
# 用于：模板短链接生成与存储
# 默认值：https://data.tanshilong.com/api/share
# 示例：https://your-api.com/api/share
VITE_SHARE_API_URL=

# AI 词条生成服务 API 地址
# 用于：AI 驱动的词条扩展功能
# 默认值：https://data.tanshilong.com/api/ai/process
# 示例：https://your-api.com/api/ai/process
VITE_AI_API_URL=

# Data Sync Configuration
# Override the default cloud data source URL. Leave empty to use the built-in public server.
VITE_DATA_API_URL=

# Dev Server Allowed Hosts
# Comma-separated list of hostnames allowed to connect to the Vite dev server.
# Leave empty to allow all hosts (default when not set).
VITE_ALLOWED_HOSTS=
# 数据云端同步地址
# 用于：模板和词库的云端版本检查
# 默认值：https://data.tanshilong.com/data
VITE_DATA_CLOUD_URL=

# ==========【应用配置】==========

# 官网 URL（用于分享、导出和跳转链接）
# 默认值：https://aipromptfill.com
# 示例：https://example.com
VITE_PUBLIC_URL=

# ==========【CDN 和资源配置】==========

# QR 码生成服务 API
# 默认值：https://api.qrserver.com/v1/create-qr-code/
# 备选：https://goqr.me/api/  或使用本地库 (qrcode.js)
VITE_QR_API_URL=

# 图片代理服务（用于跨域图片访问）
# 默认值：https://images.weserv.nl/
# 备选：https://images.bgkill.com/  （国内友好）
VITE_IMAGE_PROXY_URL=

# 模板资源 CDN 前缀
# 用于：模板预览图、视频资源的 URL 前缀
# 示例：https://cdn.example.com/  或 https://s3.amazonaws.com/bucket/
VITE_CDN_PREFIX=

# ==========【Tauri 特定配置】==========

# Tauri 构建平台（自动设置，通常不需要手动配置）
# 可选值：linux, windows, macos, android, ios
# TAURI_PLATFORM=

# Tauri 调试模式（自动设置）
# TAURI_DEBUG=false

# ==========【可选：高级配置】==========

# 日志级别
# 可选值：debug, info, warn, error
# VITE_LOG_LEVEL=info

# 功能开关（见 src/constants/featureFlags.js）
# VITE_FEATURE_AI_ENABLED=true
# VITE_FEATURE_SHARE_ENABLED=true

# ==========【开发环境说明】==========
#
# 无配置情况下：
# ✅ 应用将使用内置的默认值（见各 .js 文件）
# ✅ 分享功能自动降级为长链接分享（无需后端）
# ✅ AI 功能可选（有后端时启用）
#
# 完整配置情况下：
# ✅ 所有功能均可正常使用
# ✅ 支持私有部署和自定义域名
#
# 推荐部署步骤：
# 1. 本地开发：保持所有项为空（使用默认值）
# 2. 测试环境：配置测试服务器地址
# 3. 生产环境：配置生产服务器地址
#
