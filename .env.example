# Private Share Server Configuration
# Copy this file to .env and fill in your own API URL if you have one.
# If left empty, the app will fallback to the default public server or long URL sharing.

# For Create React App / standard Webpack
REACT_APP_SHARE_API_URL=

# For Vite
VITE_SHARE_API_URL=

# AI Service Configuration
# Override the default AI API endpoint. Leave empty to use the built-in public server.
VITE_AI_API_URL=

# Data Sync Configuration
# Override the default cloud data source URL. Leave empty to use the built-in public server.
VITE_DATA_API_URL=

# Dev Server Allowed Hosts
# Comma-separated list of hostnames allowed to connect to the Vite dev server.
# Leave empty to allow all hosts (default when not set).
VITE_ALLOWED_HOSTS=
